# Copy this file to .env and fill in your keys
# Only include the keys for providers you actually use

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Job scraping (optional — needed for LinkedIn, Indeed, Glassdoor, Google Jobs)
SERPAPI_KEY=...

# Google Sheets (required for sheet sync)
# Place your service account JSON file at ./credentials/google_service_account.json
# Or set the path here:
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google_service_account.json
